<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ data extraction rules. Mirrors backup_rules.xml.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" path="." />
        <exclude domain="sharedpref" path="sandbox-session.xml" />
        <exclude domain="cache" path="." />
        <exclude domain="external_cache" path="." />
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="." />
        <exclude domain="sharedpref" path="sandbox-session.xml" />
    </device-transfer>
</data-extraction-rules>
